# ============================================================
#  Wellbot 환경변수 설정
#  이 파일을 복사하여 .env 로 저장한 뒤 값을 채워주세요.
#  cp .env.example .env
# ============================================================

# ── AWS 공통 ─────────────────────────────────────────────────
# Bedrock, S3 등 AWS 서비스 호출에 사용되는 기본 리전
AWS_REGION=ap-northeast-2

# ── 데이터베이스 ─────────────────────────────────────────────
# SQLAlchemy 접속 URL (MySQL/PyMySQL)
# 형식: mysql+pymysql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB_NAME>
DB_URL=mysql+pymysql://root:password@localhost:3306/wellbot

# ── 실행 환경 ───────────────────────────────────────────────
# KB(개인/팀) AWS 리소스 이름·S3 경로의 환경 네임스페이스 구분에 사용.
# dev/prd 가 같은 AWS 계정·버킷을 공유하므로 환경별로 분리해 충돌을 방지.
#   - dev (또는 미설정)  : 'users-dev/...', 'aiinno-...-dev' 로 생성
#   - 운영 (prd)        : 빈 값으로 두면 접미사 없이 기존 이름·경로 사용
APP_ENV=dev

# ── 인증 / 보안 ─────────────────────────────────────────────
# 관리자 페이지 접속 비밀번호 (사원번호 없이 로그인 시 사용)
ADMIN_PASSWORD=

# JWT 토큰 서명 키 (운영 환경에서는 반드시 변경)
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=wellbot-secret-key-change-in-production

# ── S3 파일 저장소 ───────────────────────────────────────────
# 첨부파일 업로드에 사용할 S3 버킷 이름 (필수)
S3_BUCKET_NAME=
S3_KEY_PREFIX=
# S3 버킷 리전 (미설정 시 AWS_REGION 값 사용)
S3_REGION=ap-northeast-2

# ── Knowledge Base 인프라 (개인/팀/공용 KB 공통) ─────────────
# 개인 KB, 팀 KB, 공용 KB 가 공유하는 AWS 인프라 자원.
# KB 파일 저장 버킷은 위 S3_BUCKET_NAME 을 공유한다.
# 세부 옵션(embedding_model, poll_interval 등)은 config/knowBase.yaml 참조.
# Custom Transformation 중간 결과 저장용 S3 버킷
KB_S3_INTERMEDIATE_BUCKET=
# S3 Vectors 인덱스 저장용 버킷
KB_S3_VECTOR_BUCKET=
# Custom Transformation Lambda ARN
KB_LAMBDA_ARN=
# Bedrock KB 생성 시 사용할 IAM Role ARN
KB_ROLE_ARN=
# 공용(회사) KB 의 Bedrock KB ID. 설정 시 config/knowBase.yaml 의 shared_kb.kb_id 를 대체.
KB_ID=

# ── Upstage Document Parse (선택) ────────────────────────────
# FILE_PARSER_MODE가 "upstage" 또는 "hybrid"일 때 필요
# constants.py의 FILE_PARSER_MODE 참조 (기본값: "local")
UPSTAGE_API_KEY=
UPSTAGE_API_URL=https://api.upstage.ai/v1/document-digitization

# ── 보고서 문구 지원 (report_maker, 선택) ────────────────────
# 세부 설정은 wellbot/services/report_maker/report_maker.yaml 참조.
# 파일은 앱 공통 S3(S3_BUCKET_NAME / S3_KEY_PREFIX)를 재사용한다.
#
# AgentCore 스타일 메모리 ID. 미설정 시 스타일 프로파일은 S3(combined_style)만으로
# 동작한다(AgentCore 사용하려면 bedrock_agentcore 패키지 설치 + 이 값 설정 필요).
REPORT_MAKER_MEMORY_ID=
# LLM 모델 오버라이드(미설정 시 report_maker.yaml 의 model_id 사용)
# REPORT_MAKER_MODEL_ID=

# ── 로깅 ─────────────────────────────────────────────────────
# 환경 프리셋: dev(컬러 콘솔, 파일 비활성) | prod(JSON, 파일 활성)
LOG_ENV=dev
# 로그 레벨: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# 콘솔 출력 포맷: console(사람이 읽기) | json (미설정 시 LOG_ENV로 자동 결정)
# LOG_FORMAT=console
# 파일 출력 여부 (미설정 시 prod=true, dev=false). 파일은 항상 JSON 으로 적재
# LOG_TO_FILE=false
# 로그 파일 디렉토리 (기본: <project>/logs)
# LOG_DIR=
# 회전 파일 1개 최대 크기(MB)와 보관 개수
LOG_FILE_MAX_MB=50
LOG_FILE_BACKUPS=5
# 콘솔 컬러 (미설정 시 dev=true, prod=false)
# LOG_COLOR=true
