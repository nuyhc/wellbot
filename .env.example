# ============================================================
#  Wellbot 환경변수 설정
#  이 파일을 복사하여 .env 로 저장한 뒤 값을 채워주세요.
#  cp .env.example .env
# ============================================================

# ── AWS 공통 ─────────────────────────────────────────────────
# Bedrock, S3 등 AWS 서비스 호출에 사용되는 기본 리전
AWS_REGION=ap-northeast-2

# ── 데이터베이스 ─────────────────────────────────────────────
# SQLAlchemy 접속 URL (MySQL/PyMySQL)
# 형식: mysql+pymysql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB_NAME>
DB_URL=mysql+pymysql://root:password@localhost:3306/wellbot

# ── 인증 / 보안 ─────────────────────────────────────────────
# 관리자 페이지 접속 비밀번호 (사원번호 없이 로그인 시 사용)
ADMIN_PASSWORD=

# JWT 토큰 서명 키 (운영 환경에서는 반드시 변경)
JWT_SECRET=wellbot-secret-key-change-in-production

# ── S3 파일 저장소 ───────────────────────────────────────────
# 첨부파일 업로드에 사용할 S3 버킷 이름 (필수)
S3_BUCKET_NAME=
S3_KEY_PREFIX=
# S3 버킷 리전 (미설정 시 AWS_REGION 값 사용)
S3_REGION=ap-northeast-2

# ── Upstage Document Parse (선택) ────────────────────────────
# FILE_PARSER_MODE가 "upstage" 또는 "hybrid"일 때 필요
# constants.py의 FILE_PARSER_MODE 참조 (기본값: "local")
UPSTAGE_API_KEY=
UPSTAGE_API_URL=https://api.upstage.ai/v1/document-digitization
